{
  "manifest_version": 3,
  "name": "Chromium Voice + Eye Agent",
  "version": "1.0",
  "description": "Local-only, privacy-first voice and gaze assistant.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "Voice Agent Settings"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
